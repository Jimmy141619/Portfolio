def login():
    # Only collect essential data
    username = input("Enter username: ")
    password = input("Enter password: ")

    # Basic validation (no extra data collected)
    if len(username) == 0 or len(password) == 0:
        print("Invalid input")
        return

    print("\nLogin processed.")
    print("Only required data was used.")

    # Clear sensitive data (not stored)
    username = None
    password = None

login()
